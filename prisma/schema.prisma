// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// 1. Core / SaaS / Auth
model Organization {
  id        String   @id @default(uuid())
  name      String
  slug      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Store Settings
  whatsappPhone String?
  isOpen        Boolean @default(true)
  deliveryFee   Decimal @default(0) @db.Decimal(10, 2)

  // Relations
  members     Profile[]
  ingredients Ingredient[]
  products    Product[]
  customers   Customer[]
}

model Profile {
  id             String        @id // Matches Supabase Auth ID
  email          String
  fullName       String?
  role           Role          @default(STAFF)
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
}

enum Role {
  OWNER
  ADMIN
  STAFF
}

// 2. Inventory & Menu Engineering
model Ingredient {
  id             String       @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  name          String
  unit          String // kg, g, l, un
  pricePerUnit  Decimal @db.Decimal(10, 2)
  minStockLevel Decimal @default(0) @db.Decimal(10, 2)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Used in recipes
  recipes ProductRecipe[]
}

enum ProductType {
  ITEM
  COMPOSITE
  COMPONENT
}

model Product {
  id             String       @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  name        String
  shortName   String? // e.g. "Penne" vs "Macarrão Penne 500g"
  description String?
  basePrice   Decimal @db.Decimal(10, 2)
  imageUrl    String?
  categoryId  String? // Can be an enum or relation later

  type ProductType @default(ITEM)

  isDishOfTheDay   Boolean  @default(false)
  promotionalPrice Decimal? @db.Decimal(10, 2)
  serves           Int?     @default(1)

  // Unified Inventory Fields (Replacing Ingredient model)
  // Unified Inventory Fields (Replacing Ingredient model)
  costPrice     Decimal @default(0) @db.Decimal(10, 2)
  stock         Decimal @default(0) @db.Decimal(10, 2)
  unit          String  @default("un") // kg, g, l, un
  minStockLevel Decimal @default(0) @db.Decimal(10, 2)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  recipes         ProductRecipe[]
  modifiers       ProductModifier[]
  orderItems      OrderItem[]
  modifierOptions ModifierOption[]
}

// Composition: How much of an ingredient is used to make a product
model ProductRecipe {
  id        String  @id @default(uuid())
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  ingredientId String
  ingredient   Ingredient @relation(fields: [ingredientId], references: [id])

  quantity Decimal @db.Decimal(10, 4) // e.g. 0.150 (kg)

  createdAt DateTime @default(now())
}

// Customization: "Monte seu Pastel" options (e.g. Size, Dough Type, Fillings group)
model ProductModifier {
  id        String  @id @default(uuid())
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  name         String // e.g. "Tamanho", "Recheio"
  sequence     Int    @default(0) // Step order
  minSelection Int    @default(1)
  maxSelection Int    @default(1)

  // New: Control if options in this group should add to the price
  enablePrice Boolean @default(true)

  options ModifierOption[]
}

model ModifierOption {
  id         String          @id @default(uuid())
  modifierId String
  modifier   ProductModifier @relation(fields: [modifierId], references: [id], onDelete: Cascade)

  name  String // e.g. "Grande", "Carne"
  price Decimal @default(0) @db.Decimal(10, 2)

  // New: Link to a specific product/ingredient (for stock/naming)
  linkedProductId String?
  linkedProduct   Product? @relation(fields: [linkedProductId], references: [id])

  // New: Quantity to deduct from stock (e.g. 1 unit, 0.200 kg)
  quantity Decimal @default(1) @db.Decimal(10, 4)
}

// 3. CRM & Sales
model Customer {
  id             String       @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  name  String
  phone String?
  email String?

  addresses CustomerAddress[]
  orders    Order[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CustomerAddress {
  id         String   @id @default(uuid())
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  street       String
  number       String
  complement   String?
  neighborhood String?
  city         String?
  zipCode      String?

  isDefault Boolean @default(false)
}

model Order {
  id             String    @id @default(uuid())
  organizationId String
  customerId     String?
  customer       Customer? @relation(fields: [customerId], references: [id])

  status      OrderStatus @default(PENDING)
  totalAmount Decimal     @db.Decimal(10, 2)
  deliveryFee Decimal     @default(0) @db.Decimal(10, 2)

  paymentMethod   String? // pix, credit_card, cash
  deliveryMethod  DeliveryMethod @default(DELIVERY)
  notes           String?
  addressSnapshot Json? // Stores the full address at the time of order

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items OrderItem[]
}

enum DeliveryMethod {
  DELIVERY
  PICKUP
}

model OrderItem {
  id      String @id @default(uuid())
  orderId String
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  productId String
  product   Product @relation(fields: [productId], references: [id])

  quantity  Int
  unitPrice Decimal @db.Decimal(10, 2) // Snapshot price

  // JSON to store specific customizations selected (e.g. "Sem cebola", "Massa Crocante")
  customizations Json?
}

enum OrderStatus {
  PENDING
  PREPARING
  READY
  DELIVERING
  COMPLETED
  CANCELLED
}
